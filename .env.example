# ── WWW Studio Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values
# ⚠️  NEVER commit .env to git — it is in .gitignore

# ── Client-side (VITE_ prefixed — safe in browser bundle) ─────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Server-only (NEVER expose to browser) ────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://postgres:***@localhost:5432/wwwstudio

# ── API Server ───────────────────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000

# ── Optional: AI Integration ────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here

# ── Optional: GitHub OAuth / Storage ─────────────────────────────────────────
GITHUB_OAUTH_TOKEN=your-github-personal-access-token-here

# ── Build Environment ────────────────────────────────────────────────────────
NODE_ENV=production
